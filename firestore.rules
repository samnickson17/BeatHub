rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Users: any authenticated user can read any profile,
    // but only the owner can write their own document.
    match /users/{userId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && request.auth.uid == userId;

      match /following/{targetId} {
        allow read: if request.auth != null;
        allow write: if request.auth != null && request.auth.uid == userId;
      }
      match /followers/{followerId} {
        allow read: if request.auth != null;
        allow write: if request.auth != null;
      }
    }

    // Beats: any authenticated user can read; any auth user can write (producers only in practice)
    match /beats/{beatId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null;
    }

    // Purchases: any authenticated user can read/write (scoped by buyerUserId in queries)
    match /purchases/{purchaseId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null;
    }
  }
}
