[
  {
    "origin": ["*"],
    "method": ["GET", "HEAD", "PUT", "POST", "DELETE", "OPTIONS"],
    "responseHeader": [
      "Content-Type",
      "Content-Length",
      "Authorization",
      "Accept",
      "Range",
      "X-Requested-With",
      "Access-Control-Allow-Origin"
    ],
    "maxAgeSeconds": 3600
  }
]
